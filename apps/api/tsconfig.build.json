{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Pinned explicitly: without it, TypeScript infers the common source
    // directory from the input set, so adding prisma/seed.ts silently moved
    // the build output from dist/main.js to dist/src/main.js.
    "rootDir": "./src"
  },
  "exclude": ["node_modules", "test", "dist", "prisma", "**/*spec.ts"]
}
