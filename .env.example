# Root env — used by docker-compose.yml for variable substitution.
# Copy to .env before running `docker compose up`.
# Per-app .env.example files (apps/web, apps/api) are for non-Docker `pnpm dev`.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cinetrack

JWT_SECRET=changeme
TMDB_API_KEY=changeme

NEXT_PUBLIC_API_URL=http://localhost:4000
